# Puerto del auth-service (3005 local, 3000 en Docker)
PORT=3005

# PostgreSQL - Conexión
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=auth_db

# JWT - Obligatorio en producción
JWT_SECRET=superSecretKey

# CORS - Orígenes permitidos (separados por coma). * = todos
CORS_ORIGIN=*
