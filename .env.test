# Puerto del auth-service para tests
PORT=3006

# PostgreSQL - Base de datos de test
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_USERNAME=postgres
DB_PASSWORD=postgres
# Usar auth_db para tests (crear auth_db_test si se desea aislamiento)
DB_NAME=auth_db

# JWT para tests
JWT_SECRET=testSecretKeyForJWT

# CORS
CORS_ORIGIN=*
